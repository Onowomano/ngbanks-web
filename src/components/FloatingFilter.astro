---
import banksData from "../data/banks.json";

const categoryMap = new Map<string, number>();
for (const bank of banksData) {
  const cat = bank.category as string;
  categoryMap.set(cat, (categoryMap.get(cat) ?? 0) + 1);
}
const categories = [...categoryMap.entries()].sort((a, b) =>
  a[0].localeCompare(b[0]),
);

function formatCategory(cat: string): string {
  return cat.replace(/_/g, " ");
}

const styleOptions = ["circle", "square", "bubble"];
---

<div class="ff" id="ff">
  <!-- Filter content — hidden when collapsed -->
  <div class="ff__body" id="ff-body">
    <div class="ff__section">
      <span class="ff__section-label">style</span>
      <div class="ff__rows">
        {
          styleOptions.map((opt, i) => (
            <label class="ff__row">
              <span class="ff__ctrl-wrap">
                <input
                  type="radio"
                  class="ff__radio"
                  name="logo-style"
                  value={opt}
                  checked={i === 0}
                />
                <span class="ff__radio-disc" aria-hidden="true" />
              </span>
              <span class="ff__row-label">{opt}</span>
            </label>
          ))
        }
      </div>
    </div>

    <div class="ff__section">
      <span class="ff__section-label">banks</span>
      <div class="ff__rows">
        <label class="ff__row">
          <span class="ff__ctrl-wrap">
            <input
              type="radio"
              class="ff__radio ff__bank-radio"
              name="bank-category"
              value="all"
              checked
            />
            <span class="ff__radio-disc" aria-hidden="true"></span>
          </span>
          <span class="ff__row-label">all</span>
        </label>
        {
          categories.map(([cat, count]) => (
            <label class="ff__row">
              <span class="ff__ctrl-wrap">
                <input
                  type="radio"
                  class="ff__radio ff__bank-radio"
                  name="bank-category"
                  value={cat}
                />
                <span class="ff__radio-disc" aria-hidden="true" />
              </span>
              <span class="ff__row-label">
                {formatCategory(cat)} ({count})
              </span>
            </label>
          ))
        }
      </div>
    </div>
  </div>

  <!-- Single toggle pill -->
  <button class="ff__pill" id="ff-pill" type="button">
    <span class="ff__pill-text">
      <span id="ff-filter-txt">Filter</span>
      <span id="ff-close-txt" aria-hidden="true">Close</span>
    </span>
    <span class="ff__pill-icon" aria-hidden="true">
      <!-- chevron-up (collapsed) -->
      <svg
        id="ff-chevron"
        width="20"
        height="20"
        viewBox="0 0 20 20"
        fill="none"
        xmlns="http://www.w3.org/2000/svg"
      >
        <path
          d="M5 12.5L10 7.5L15 12.5"
          stroke="currentColor"
          stroke-width="1.2"
          stroke-linecap="round"
          stroke-linejoin="round"></path>
      </svg>
      <!-- × (expanded) -->
      <svg
        id="ff-x"
        width="20"
        height="20"
        viewBox="0 0 20 20"
        fill="none"
        xmlns="http://www.w3.org/2000/svg"
      >
        <path
          d="M15 5L5 15M5 5L15 15"
          stroke="currentColor"
          stroke-width="1.2"
          stroke-linecap="round"
          stroke-linejoin="round"></path>
      </svg>
    </span>
  </button>
</div>

<style>
  @media (max-width: 1023px) {
    .ff {
      display: none;
    }
  }

  .ff {
    position: fixed;
    bottom: 20px;
    right: 20px;
    z-index: 100;
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 24px;
    border-radius: 8px;
    width: 210px;
  }

  /* ── Body ───────────────────────────────────── */
  .ff__body {
    display: none;
    flex-direction: column;
    align-items: flex-start;
    padding: 8px;
    gap: 12px;
    width: 100%;
  }

  /* ── Section ────────────────────────────────── */
  .ff__section {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 6px;
    width: 100%;
  }

  .ff__section-label {
    font-family: "Inter", sans-serif;
    font-size: 14px;
    font-weight: 400;
    color: #6b7280;
    letter-spacing: -0.02em;
    line-height: 20px;
  }

  /* ── Rows ───────────────────────────────────── */
  .ff__rows {
    display: flex;
    flex-direction: column;
    gap: 6px;
    width: 100%;
  }

  .ff__row {
    display: flex;
    flex-direction: row;
    align-items: center;
    gap: 8px;
    width: 100%;
    cursor: pointer;
  }

  .ff__row-label {
    font-family: "Inter", sans-serif;
    font-size: 14px;
    font-weight: 400;
    color: #ffffff;
    letter-spacing: -0.02em;
    line-height: 20px;
    user-select: none;
  }

  /* ── Control wrap ───────────────────────────── */
  .ff__ctrl-wrap {
    position: relative;
    width: 16px;
    height: 16px;
    flex-shrink: 0;
  }

  /* ── Radio ──────────────────────────────────── */
  .ff__radio {
    position: absolute;
    inset: 0;
    opacity: 0;
    width: 100%;
    height: 100%;
    cursor: pointer;
    margin: 0;
  }

  .ff__radio-disc {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 16px;
    height: 16px;
    border: 1.5px solid #ffffff;
    border-radius: 99999px;
    background: transparent;
    pointer-events: none;
  }

  .ff__radio-disc::after {
    content: "";
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: transparent;
    transition: background 0.12s ease;
  }

  .ff__radio:checked + .ff__radio-disc::after {
    background: #ffffff;
  }

  .ff__radio:focus-visible + .ff__radio-disc {
    outline: 2px solid rgba(255, 255, 255, 0.4);
    outline-offset: 2px;
  }

  /* ── Pill text crossfade ────────────────────── */
  .ff__pill-text {
    position: relative;
    display: inline-block;
  }

  #ff-close-txt {
    position: absolute;
    left: 0;
    top: 0;
    opacity: 0;
    white-space: nowrap;
  }

  /* ── Pill icon crossfade ────────────────────── */
  .ff__pill-icon {
    position: relative;
    width: 20px;
    height: 20px;
    flex-shrink: 0;
  }

  .ff__pill-icon svg {
    position: absolute;
    top: 0;
    left: 0;
  }

  #ff-x {
    opacity: 0;
  }

  /* ── Pill ───────────────────────────────────── */
  .ff__pill {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 4px;
    padding: 8px 8px 8px 16px;
    height: 36px;
    background: rgba(3, 7, 18, 0.8);
    border: none;
    border-radius: 9999px;
    font-family: "Inter", sans-serif;
    font-size: 16px;
    font-weight: 400;
    color: #ffffff;
    letter-spacing: -0.02em;
    line-height: 20px;
    cursor: pointer;
    white-space: nowrap;
    transition: background 0.15s ease;
  }

  .ff__pill:hover {
    background: rgba(3, 7, 18, 1);
  }
</style>

<script>
  import gsap from "gsap";

  const ff = document.getElementById("ff")!;
  const body = document.getElementById("ff-body") as HTMLDivElement;
  const pill = document.getElementById("ff-pill") as HTMLButtonElement;
  const filterTxt = document.getElementById("ff-filter-txt")!;
  const closeTxt = document.getElementById("ff-close-txt")!;
  const chevron = document.getElementById("ff-chevron")!;
  const xIcon = document.getElementById("ff-x")!;

  let isOpen = false;

  function transitionToClose() {
    gsap.killTweensOf([filterTxt, closeTxt, chevron, xIcon]);
    // Text: Filter slides up + fades, Close slides in from below
    gsap.to(filterTxt, {
      opacity: 0,
      y: -5,
      duration: 0.14,
      ease: "power2.in",
    });
    gsap.set(closeTxt, { y: 5 });
    gsap.to(closeTxt, {
      opacity: 1,
      y: 0,
      duration: 0.18,
      delay: 0.08,
      ease: "power2.out",
    });
    // Icon: chevron rotates out, X rotates in
    gsap.to(chevron, {
      opacity: 0,
      rotate: 45,
      scale: 0.65,
      duration: 0.16,
      ease: "power2.in",
    });
    gsap.set(xIcon, { rotate: -45, scale: 0.65 });
    gsap.to(xIcon, {
      opacity: 1,
      rotate: 0,
      scale: 1,
      duration: 0.2,
      delay: 0.08,
      ease: "back.out(1.4)",
    });
  }

  function transitionToFilter() {
    gsap.killTweensOf([filterTxt, closeTxt, chevron, xIcon]);
    // Text: Close slides up + fades, Filter slides in from below
    gsap.to(closeTxt, { opacity: 0, y: -5, duration: 0.14, ease: "power2.in" });
    gsap.set(filterTxt, { y: 5 });
    gsap.to(filterTxt, {
      opacity: 1,
      y: 0,
      duration: 0.18,
      delay: 0.08,
      ease: "power2.out",
    });
    // Icon: X rotates out, chevron rotates in
    gsap.to(xIcon, {
      opacity: 0,
      rotate: 45,
      scale: 0.65,
      duration: 0.16,
      ease: "power2.in",
    });
    gsap.set(chevron, { rotate: -45, scale: 0.65 });
    gsap.to(chevron, {
      opacity: 1,
      rotate: 0,
      scale: 1,
      duration: 0.2,
      delay: 0.08,
      ease: "back.out(1.4)",
    });
  }

  function openFilter() {
    isOpen = true;
    transitionToClose();

    gsap.set(body, { display: "flex", opacity: 0, y: 10 });

    gsap
      .timeline()
      .to(ff, {
        backgroundColor: "#040914",
        duration: 0.3,
        ease: "power3.out",
      })
      .to(
        body,
        { opacity: 1, y: 0, duration: 0.25, ease: "power2.out" },
        "<0.06",
      );
  }

  function closeFilter() {
    isOpen = false;
    transitionToFilter();

    gsap
      .timeline({
        onComplete() {
          gsap.set(body, { display: "none" });
          gsap.set(ff, { clearProps: "backgroundColor,padding" });
        },
      })
      .to(body, { opacity: 0, y: 10, duration: 0.2, ease: "power2.in" })
      .to(
        ff,
        {
          backgroundColor: "rgba(0,0,0,0)",
          padding: 0,
          duration: 0.25,
          ease: "power3.in",
        },
        "<0.06",
      );
  }

  pill.addEventListener("click", () => {
    if (isOpen) closeFilter();
    else openFilter();
  });

  document.addEventListener("click", (e) => {
    if (isOpen && !ff.contains(e.target as Node)) closeFilter();
  });

  // Dispatch category filter when a bank radio changes
  const bankRadios = ff.querySelectorAll<HTMLInputElement>(".ff__bank-radio");

  function dispatchFilter() {
    const selected = ff.querySelector<HTMLInputElement>(
      ".ff__bank-radio:checked",
    );
    const category = selected?.value ?? "all";
    filterTxt.textContent = category === "all" ? "Filter" : "Filter (1)";
    window.dispatchEvent(
      new CustomEvent("ff:filter", { detail: { category } }),
    );
  }

  bankRadios.forEach((r) => r.addEventListener("change", dispatchFilter));
</script>
