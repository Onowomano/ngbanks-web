    <div class="bc-rule"></div>

    <!-- Search -->
    <div class="bc-search">
      <svg
        class="bc-search__icon"
        width="20"
        height="20"
        viewBox="0 0 20 20"
        fill="none"
        aria-hidden="true"
        xmlns="http://www.w3.org/2000/svg"
      >
        <path
          d="M17.5 17.5L13.9166 13.9166M15.8333 9.16667C15.8333 12.8486 12.8486 15.8333 9.16667 15.8333C5.48477 15.8333 2.5 12.8486 2.5 9.16667C2.5 5.48477 5.48477 2.5 9.16667 2.5C12.8486 2.5 15.8333 5.48477 15.8333 9.16667Z"
          stroke="#04000A"
          stroke-width="1.66667"
          stroke-linecap="round"
          stroke-linejoin="round"></path>
      </svg>

      <input
        id="bc-search"
        type="text"
        placeholder="Search"
        autocomplete="off"
        spellcheck="false"
        aria-label="Search banks"
      />
    </div>
    <div class="bc-rule"></div>

    <!-- Bank list -->
    <div
      class="bc-list"
      id="bc-list"
      role="list"
      aria-live="polite"
      aria-label="Bank list"
    >
    </div>
    <div class="bc-indicator"></div>
  </div>
</div>

<script>
  const list = document.getElementById("bc-list")!;
  const input = document.getElementById("bc-search") as HTMLInputElement;
  const statusTime = document.querySelector(".bc-status__time");

  function updateStatusTime() {
    if (!statusTime) return;

    const now = new Date();
    const hours = now.getHours();
    const minutes = String(now.getMinutes()).padStart(2, "0");

    statusTime.textContent = `${hours}:${minutes}`;
  }

  updateStatusTime();
  setInterval(updateStatusTime, 1000);

  type Bank = {
    name: string;
    category: string;
    logo: string;
    aliases: string[];
  };
  let banks: Bank[] = [];
  let activeCategories: Set<string> | null = null; // null = all

  const BATCH = 50;
  const PLACEHOLDER = "/default-bank.svg";
  let swapEpoch = 0;

  function renderSkeletons(n = 10) {
    list.innerHTML = Array.from(
      { length: n },
      () => `
      <div class="bc-row bc-row--skeleton" aria-hidden="true">
        <div class="bc-logo bc-skel"></div>
        <div class="bc-skel bc-skel--name"></div>
      </div>
    `,
    ).join("");
  }

  function row(b: Bank, logoSrc: string, id = "") {
    return `
      <div class="bc-row" role="listitem" data-category="${b.category}">
        <div class="bc-logo">
          <img${id ? ` id="${id}"` : ""} src="${logoSrc}" alt="${b.name}">
        </div>
        <span class="bc-row__name">${b.name}</span>
      </div>`;
  }

  function preload(src: string): Promise<void> {
    return new Promise((resolve) => {
      const img = new Image();
      img.onload = img.onerror = () => resolve();
      img.src = src;
    });
  }

  function swapLogo(id: string, src: string, epoch: number) {
    const img = new Image();
    img.onload = () => {
      if (swapEpoch !== epoch) return;
      const el = document.getElementById(id) as HTMLImageElement | null;
      if (el) el.src = src;
    };
    img.src = src;
  }

  function renderAll(data: Bank[]) {
    swapEpoch++;
    if (!data.length) {
      list.innerHTML = '<p class="bc-empty">No banks found</p>';
      return;
    }
    list.innerHTML = data.map((b) => row(b, b.logo)).join("");
  }

  function getFiltered(): Bank[] {
    const q = input.value.toLowerCase().trim();
    let data = banks;
    if (activeCategories !== null) {
      data = data.filter((b) => activeCategories!.has(b.category));
    }
    if (q) {
      data = data.filter(
        (b) =>
          b.name.toLowerCase().includes(q) ||
          b.aliases.some((a) => a.toLowerCase().includes(q)),
      );
    }
    return data;
  }

  async function init() {
    renderSkeletons();
    const res = await fetch("/api/banks.json");
    banks = await res.json();

    const first = banks.slice(0, BATCH);
    const rest = banks.slice(BATCH);

    await Promise.all(first.map((b) => preload(b.logo)));

    swapEpoch++;
    const epoch = swapEpoch;

    list.innerHTML = first.map((b) => row(b, b.logo)).join("");

    if (rest.length) {
      list.insertAdjacentHTML(
        "beforeend",
        rest.map((b, i) => row(b, PLACEHOLDER, `bl-${BATCH + i}`)).join(""),
      );
      rest.forEach((b, i) => swapLogo(`bl-${BATCH + i}`, b.logo, epoch));
    }
  }

  input.addEventListener("input", () => {
    renderAll(getFiltered());
  });

  window.addEventListener("ff:filter", (e) => {
    const { category } = (e as CustomEvent<{ category: string }>).detail;
    activeCategories = category === "all" ? null : new Set([category]);
    renderSkeletons();
    setTimeout(() => renderAll(getFiltered()), 10);
  });

  init();
</script>

<style is:global>
  /* ── Outer frame ──────────────────────────── */
  .bc-outer {
    width: 100%;
    height: 812px;
    background: white;
    border: 1.5px solid #eaeaea;
    border-radius: 56px;
    padding: 20px;
    box-sizing: border-box;
    box-shadow: 0 12px 40px rgba(0, 0, 0, 0.08);
    flex-shrink: 0;
  }

  /* ── Inner frame ──────────────────────────── */
  .bc-inner {
    position: relative;
    height: 100%;
    border: 1.5px solid #eaeaea;
    border-radius: 34px;
    display: flex;
    flex-direction: column;
    overflow: hidden;
  }

  /* ── Status bar ───────────────────────────── */
  .bc-status {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 10px 20px;
    height: 44px;
    flex-shrink: 0;
  }

  .bc-status__time {
    font-size: 13px;
    font-weight: 500;
    color: #030712;
    letter-spacing: -0.02em;
  }

  .bc-status__icons {
    display: flex;
    align-items: center;
    gap: 6px;
  }

  .bc-notch {
    position: absolute;
    margin-top: 2px;
    left: 50%;
    transform: translateX(-50%);
    width: 84px;
    height: 20px;
    border: solid 1.5px #eaeaea;
    border-radius: 9999px;
  }

  /* ── Header ───────────────────────────────── */
  .bc-header {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 8px 16px 12px;
    height: 56px;
    flex-shrink: 0;
    border-bottom: 1.5px solid #eaeaea;
  }

  .bc-header__back {
    display: flex;
    align-items: center;
    justify-content: center;
    background: #fff;
    border: 1.5px solid #eaeaea;
    padding: 6px;
    height: 32px;
    width: 32px;
    cursor: pointer;
    border-radius: 999px;
  }

  .bc-slot {
    width: 32px;
    height: 32px;
    flex-shrink: 0;
  }

  .bc-header__back:hover circle {
    color: #d1d5de;
  }

  .bc-header__title {
    flex: 1;
    font-size: 16px;
    font-weight: 500;
    color: #030712;
    letter-spacing: -0.02em;
    text-align: center;
  }

  /* ── Search bar ───────────────────────────── */
  .bc-search {
    position: relative;
    padding: 10px 16px;
    flex-shrink: 0;
    z-index: 1;
  }

  .bc-search::after {
    content: "";
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    height: 24px;
    transform: translateY(100%);
    background: linear-gradient(to bottom, #ffffff, transparent);
    pointer-events: none;
  }

  .bc-search__icon {
    position: absolute;
    left: 29px;
    top: 50%;
    transform: translateY(-50%);
    pointer-events: none;
  }

  .bc-search input {
    width: 100%;
    height: 42px;
    border: 1.5px solid #eaeaea;
    border-radius: 6px;
    padding: 0 12px 0 38px;
    font-family: inherit;
    font-size: 16px;
    color: #030712;
    letter-spacing: -0.02em;
    outline: none;
    box-sizing: border-box;
    background: white;
  }

  .bc-search input::placeholder {
    color: #6b7280;
  }

  .bc-search input:focus {
    border-color: #d1d5db;
  }

  /* ── Bank list ────────────────────────────── */
  .bc-list {
    flex: 1;
    overflow-y: auto;
    scrollbar-width: thin;
    scrollbar-color: #eaeaea transparent;
    padding-bottom: max(0px, 908px - 100vh);
  }

  .bc-list::-webkit-scrollbar {
    width: 4px;
  }
  .bc-list::-webkit-scrollbar-thumb {
    background: #eaeaea;
    border-radius: 2px;
  }

  /* ── Home Indicator ─────────────────────────────── */

  .bc-indicator {
    position: absolute;
    left: 50%;
    transform: translateX(-50%);
    bottom: 0;
    width: 120px;
    margin-bottom: 8px;
    height: 4.8px;
    background: #000;
    border-radius: 9999px;
  }

  /* ── Bank row ─────────────────────────────── */
  .bc-row {
    display: flex;
    flex-direction: row;
    align-items: center;
    gap: 12px;
    padding: 10px 16px;
    position: relative;
    flex-shrink: 0;
  }

  /* Divider starts after logo: 16px pad + 32px logo + 12px gap = 60px */
  .bc-row:not(:last-child)::after {
    content: "";
    position: absolute;
    left: 60px;
    right: 0;
    bottom: 0;
    height: 1px;
    background: #eaeaea;
  }

  /* ── Logo circle ──────────────────────────── */
  .bc-logo {
    width: 32px;
    height: 32px;
    border-radius: 9999px;
    flex-shrink: 0;
    overflow: hidden;
  }

  .bc-logo img {
    width: 100%;
    height: 100%;
    object-fit: contain;
    display: block;
  }

  /* ── Row name ─────────────────────────────── */
  .bc-row__name {
    flex: 1;
    min-width: 0;
    font-size: 16px;
    font-weight: 400;
    color: #030712;
    letter-spacing: -0.02em;
    line-height: 20px;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  /* ── Empty state ──────────────────────────── */
  .bc-empty {
    padding: 32px 16px;
    text-align: center;
    font-size: 14px;
    color: #6b7280;
  }

  /* ── Skeleton ─────────────────────────────── */
  @keyframes bc-shimmer {
    from {
      background-position: -200% 0;
    }
    to {
      background-position: 200% 0;
    }
  }

  .bc-skel {
    background: linear-gradient(90deg, #f0f0f0 25%, #e0e0e0 50%, #f0f0f0 75%);
    background-size: 200% 100%;
    animation: bc-shimmer 1.4s ease-in-out infinite;
    border-radius: 4px;
  }

  .bc-row--skeleton .bc-logo.bc-skel {
    border-radius: 50%;
  }

  .bc-skel--name {
    flex: 1;
    height: 14px;
    max-width: 55%;
  }
</style>
